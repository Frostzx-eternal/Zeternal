-- Função segura para invocar remote
local function SafeInvokeServer(value)
    if not AntiBan.Enabled then
        pcall(function()
            remote:InvokeServer(value)
        end)
        return
    end
    
    -- Aplicar medidas preventivas
    ApplyPreventiveMeasures()
    
    -- Verificar status de suspeita
    if CheckBanStatus() then
        print("ALERTA: Comportamento suspeito detectado!")
        AntiBanStatus:SetTitle("Sistema Anti-Ban")
        AntiBanStatus:SetContent("Status: Alerta!\nNível de Suspeita: " .. AntiBan.SuspicionLevel .. "/10")
        return
    end
    
    -- Executar ação com delay randomizado
    local success, err = pcall(function()
        remote:InvokeServer(value)
    end)
    
    if not success then
        AntiBan.ErrorRate = AntiBan.ErrorRate + 0.01
    else
        AntiBan.ErrorRate = math.max(0, AntiBan.ErrorRate - 0.005)
    end
    
    -- Atualizar status
    AntiBanStatus:SetTitle("Sistema Anti-Ban")
    AntiBanStatus:SetContent("Status: Ativo\nNível de Suspeita: " .. AntiBan.SuspicionLevel .. "/10")
end

